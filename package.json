{
	"name": "@iamalond/nestjs-i18next",
	"description": "🌍 i18next module for NestJS",
	"version": "1.3.2",
	"scripts": {
		"build": "rimraf -rf dist && tsc -p tsconfig.build.json",
		"prepublish:npm": "npm run build",
		"publish:npm": "release-it",
		"commit": "cz",
		"prepublish:dev": "npm run build",
		"publish:dev": "npm publish --access public --tag dev",
		"prepare": "husky",
		"format": "prettier --write \"{src,apps,libs,test}/**/*.ts\"",
		"lint": "eslint --ignore-pattern .gitignore \"{src,apps,libs,test}/**/*.ts\"",
		"lint:fix": "npm run lint -- --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:ci": "jest --ci --passWithNoTests --coverage"
	},
	"lint-staged": {
		"*.ts": [
			"npm run format",
			"npm run lint:fix"
		]
	},
	"directories": {
		"lib": "src",
		"test": "test"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"keywords": [
		"nestjs",
		"i18n",
		"i18next",
		"internationalization",
		"internationalisation",
		"internationalize",
		"internationalise",
		"international",
		"internationalize",
		"locale"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/iamAlond/nestjs-i18next.git"
	},
	"bugs": {
		"url": "https://github.com/iamAlond/nestjs-i18next"
	},
	"author": "Matvey iamAlond",
	"contributors": [
		"Matvey iamAlond"
	],
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"dependencies": {
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-angular": "20.5.0",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@nestjs/common": "11.1.19",
		"@nestjs/core": "11.1.19",
		"@nestjs/testing": "^11.1.17",
		"@release-it/conventional-changelog": "^10.0.6",
		"@types/jest": "^30.0.0",
		"@types/node": "25.6.0",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "5.5.5",
		"globals": "^17.4.0",
		"husky": "9.1.7",
		"jest": "^30.3.0",
		"lint-staged": "16.4.0",
		"prettier": "3.8.3",
		"reflect-metadata": "0.2.2",
		"release-it": "20.0.0",
		"rimraf": "6.1.3",
		"rxjs": "7.8.2",
		"ts-jest": "^29.4.9",
		"ts-node": "10.9.2",
		"typescript": "6.0.2",
		"typescript-eslint": "^8.58.0"
	},
	"peerDependencies": {
		"@nestjs/common": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
		"@nestjs/core": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
		"reflect-metadata": "^0.2.1",
		"rxjs": "^7.2.0"
	}
}
